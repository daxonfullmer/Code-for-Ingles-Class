    statics = []
    objects = [player]
    sprites = []
    items = []
    itemPool = itemPoolCopy.copy()
    player.vel = pygame.Vector2(0,0)
    player.dive = 0
    player.slideTimer = 0
    player.coyote = 0
    player.jumpSlide = False
    timestop = False
    lessgrav = False
def generateLevel():
    global objects, statics, player, sprites, items
    resetWorld()
    currentLevels = []
    for i in range(4):
        for i in range(20):
            works = True
            levelBlock = random.choice(levels)(random.randint(100, x_screen-100), random.randint(100, y_screen-100))
            for level in currentLevels:
                if levelBlock.pos.x+levelBlock.width/2 >= level.pos.x - level.width/2 and levelBlock.pos.x-levelBlock.width/2 <= level.pos.x + level.width/2 and levelBlock.pos.y+levelBlock.height/2 >= level.pos.y - level.height/2 and levelBlock.pos.y-levelBlock.height/2 <= level.pos.y + level.height/2:
                    works = False
            if works:
                currentLevels.append(levelBlock)
                break

    for level in currentLevels:
        addItem = random.randint(0,1)
        if addItem == 1 and level.statics != [] and itemPool != []: addItem = random.choice(level.statics)
        for box in level.statics:
            x, y, w, h, a = box
            if addItem is box:
                randnum = random.randint(0, len(itemPool) - 1)
                items.append(itemPool[randnum](x+level.pos.x, y+level.pos.y-h/2-30, 20))
                itemPool.remove(itemPool[randnum])
            if level == currentLevels[0] and box == level.statics[0]: player.pos = pygame.Vector2(x+level.pos.x, y + level.pos.y - h / 2 - player.height / 2 - 5)
            if player.pos.y < 0 or player.pos.x < 0 or player.pos.x > x_screen: player.pos = level.pos
            if level == currentLevels[-1] and box == level.statics[-1]: items.append(Goal(level.pos.x, level.pos.y, 20))
            square = Square(x + level.pos.x, y + level.pos.y, w, h, a)
            statics.append(square)
            square.red = level.red
            square.green = level.green
            square.blue = level.blue

        for box in level.objects:
            x, y, w, h, a = box
            square = Square(x + level.pos.x, y + level.pos.y, w, h, a)

            sprites.append((screen, (0), (level.pos.x-level.width/2, level.pos.y-level.height/2, level.width, level.height)))



prevPress = []
def keypress(press):
    if event.type == pygame.KEYDOWN and event.key == press: return True


def pushLogic(collision):
    refObject, colObject, distance = collision
    if distance == (0,0): distance = False
    elif distance.x > 0:
        colObject.pos.x = refObject.pos.x + refObject.width/2 + colObject.width/2
        refObject.vel.x = (refObject.vel.x + colObject.vel.x) / 2
        colObject.vel.x = (refObject.vel.x + colObject.vel.x) / 2
    elif distance.x < 0:
        colObject.pos.x = refObject.pos.x - refObject.width/2 - colObject.width/2
        refObject.vel.x = (refObject.vel.x + colObject.vel.x) / 2
        colObject.vel.x = (refObject.vel.x + colObject.vel.x) / 2
    elif distance.y < 0:
        colObject.pos.y = refObject.pos.y - refObject.height / 2 - colObject.height / 2
        refObject.vel.y = (refObject.vel.y + colObject.vel.y) / 2
        colObject.vel.y = (refObject.vel.y + colObject.vel.y) / 2
    elif distance.y > 0:
        colObject.pos.y = refObject.pos.y + refObject.height / 2 + colObject.height / 2
        refObject.vel.y = (refObject.vel.y + colObject.vel.y) / 2
        colObject.vel.y = (refObject.vel.y + colObject.vel.y) / 2
    collisions.remove(collision)

    if distance != False:
        refObject.pos += distance / 2
        colObject.pos += distance / 2
        inc = 0
        colliding = True
        objectCollisions = [(colObject, refObject)]
        allcolls = [colObject, refObject]
        while colliding:
            colliding = False
            for info in objectCollisions:
                refObject, prevObject, = info
                for colObject in objects:
                    if refObject == colObject: continue
                    if prevObject == colObject: continue
                    if refObject.intersectingBox(colObject):
                        colliding = True
                        allcolls.append(colObject)
                        totalVel = pygame.Vector2(0, 0)
                        for vel in allcolls:
                            totalVel += vel.vel/len(allcolls)
                        for object in allcolls:
                            if object == allcolls[0]: object.pos += distance/len(allcolls)
                            else: object.pos += distance/len(allcolls)/6
                            object.vel = totalVel/len(allcolls)

                        for collision in collisions:
                            if (collision[0] == refObject and collision[1] == colObject) or (collision[0] == colObject and collision[1] == refObject):
                                collisions.remove(collision)
                        objectCollisions.append((colObject, refObject))


            inc += 1
            if inc > 30:
                print("broke")
                for thing in allcolls:
                    thing.pos = pygame.Vector2(thing.prevPos[0], thing.prevPos[1])
                break



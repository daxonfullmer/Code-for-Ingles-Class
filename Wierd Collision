                player.pos = pygame.Vector2(pygame.mouse.get_pos())
                player.vel = pygame.Vector2(0, 0)
                player.updatePrevPos()
            if keypress(pygame.K_e): print(player.pos)
            if keypress(pygame.K_EQUALS): FPS *= 1.2
            if keypress(pygame.K_MINUS): FPS /= 1.2
            if keys[pygame.K_MINUS] and keys[pygame.K_EQUALS]: FPS = 60
            if keypress(pygame.K_r): generateLevel()
            if keypress(pygame.K_b): objects.append(Square(pygame.mouse.get_pos()[0], pygame.mouse.get_pos()[1], 50, 50, 0))
    player.detectInput(keys, upPress, downPress)

    screen.fill((backgroundRed, backgroundGreen, backgroundBlue))

    player.rightWalled = False
    player.leftWalled = False
    player.kindaRightWalled = False
    player.kindaLeftWalled = False
    upPress = False
    downPress = False
    for entity in statics:
        entity.static = True
    for entity in objects:
        entity.static = False
        entity.screenLoop()
        entity.updatePrevPos()
        entity.move()
        entity.grounded = False


    # Collision
    # for i in range(5):
    for entity in objects:
        for object in objects:
            if object == entity: continue
            distance = math.sqrt((entity.pos.x - object.pos.x) ** 2 + (entity.pos.y - object.pos.y) ** 2)
            objectRadius = math.sqrt(object.width ** 2 + object.height ** 2)
            entityRadius = math.sqrt(entity.width ** 2 + entity.height ** 2)
            if distance < (objectRadius + entityRadius) / 2:
                object.objectHitBox(entity)

        for static in statics:
            distance = math.sqrt((entity.pos.x - static.pos.x) ** 2 + (entity.pos.y - static.pos.y) ** 2)
            staticRadius = math.sqrt(static.width ** 2 + static.height ** 2)
            entityRadius = math.sqrt(entity.width ** 2 + entity.height ** 2)
            if distance < (staticRadius + entityRadius) / 2:
                entity.hitBox(static)

    # Draw
    for sprite in sprites:
        a, b, c = sprite
        pygame.draw.rect(a, b, c)
    for entity in objects:
        entity.drawRect(screen)
    for entity in statics:
        entity.drawRect(screen)



    pygame.display.flip()
    clock.tick(FPS)

pygame.quit()

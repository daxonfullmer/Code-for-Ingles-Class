            self.pos.y = other.pos.y + other.height / 2 + self.height / 2
            self.vel.y = 0
            down = True
        colliding = True
        i = 0
        collisionInfo = []
        collidedObjects = [(self, None)]
        while colliding:
            for stuff in collidedObjects:
                referenceObject, prevObject = stuff
                colliding = False
                for object in objects:

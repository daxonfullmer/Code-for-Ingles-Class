import pygame
import time
import math

debug = False
pygame.init()
screen = pygame.display.set_mode((800, 600))
clock = pygame.time.Clock()


class Entity:
    def __init__(self, x, y, width, height, angle):
        self.pos = pygame.Vector2(x, y)
        self.width = width
        self.height = height
        self.vel = pygame.Vector2(0, 0)
        self.gravity = 1
        self.grounded = False
        self.angle = angle % 360
        self.red = 0
        self.green = 0
        self.blue = 0
        self.mass = self.width*self.height
        self.points =[
            ((self.pos.x+math.sqrt(2)*self.width/2*math.cos(math.radians(self.angle+45))),
            (self.pos.y-math.sqrt(2)*self.height/2*math.sin(math.radians(self.angle+45)))),
            ((self.pos.x+math.sqrt(2)*self.width/2*math.cos(math.radians(self.angle+315))),
            (self.pos.y-math.sqrt(2)*self.height/2*math.sin(math.radians(self.angle+315)))),
            ((self.pos.x+math.sqrt(2)*self.width/2*math.cos(math.radians(self.angle+225))),
            (self.pos.y-math.sqrt(2)*self.height/2*math.sin(math.radians(self.angle+225)))),
            ((self.pos.x+math.sqrt(2)*self.width/2*math.cos(math.radians(self.angle+135))),
            (self.pos.y-math.sqrt(2)*self.height/2*math.sin(math.radians(self.angle+135))))
                       ]
        self.refPoint = self.points[0]
        self.static = True
        self.prevPoints = self.points

    def move(self):
        if self.vel.x != 0:
            if self.vel.x >= -.5 and self.vel.x <= .5: self.vel.x = 0
            elif self.vel.x > 0: self.vel.x -= .5
            elif self.vel.x < 0: self.vel.x += .5
        if self.vel.y >= 20: self.vel.y = 20
        self.pos += self.vel
        self.vel.y += self.gravity

    def drawRect(self, screen):
        surf = pygame.Surface((self.width, self.height), pygame.SRCALPHA)
        surf.fill((self.red, self.green, self.blue))

        rotated = pygame.transform.rotate(surf, self.angle)
        rect = rotated.get_rect(
            center=(self.pos.x, self.pos.y)
        )
        screen.blit(rotated, rect)
        pygame.draw.circle(screen, (255, 0, 0), (self.pos.x, self.pos.y), 5)

    def box(self, other):

        lines = [
            Geometry(self.points[0], self.points[3]),
            Geometry(self.points[3], self.points[2]),
            Geometry(self.points[2], self.points[1]),
            Geometry(self.points[1], self.points[0])
        ]

        self.points = [
            ((self.pos.x + math.sqrt(2) * self.width / 2 * math.cos(math.radians(self.angle + 45))),
             (self.pos.y - math.sqrt(2) * self.height/ 2 *math.sin(math.radians(self.angle + 45)))),
            ((self.pos.x + math.sqrt(2) * self.width / 2 *math.cos(math.radians(self.angle + 315))),
             (self.pos.y - math.sqrt(2) * self.height/ 2*math.sin(math.radians(self.angle + 315)))),
            ((self.pos.x + math.sqrt(2) * self.width / 2 *math.cos(math.radians(self.angle + 225))),
             (self.pos.y - math.sqrt(2) * self.height/ 2*math.sin(math.radians(self.angle + 225)))),
            ((self.pos.x + math.sqrt(2) * self.width / 2 *math.cos(math.radians(self.angle + 135))),
             (self.pos.y - math.sqrt(2) * self.height/ 2*math.sin(math.radians(self.angle + 135))))
        ]

        for i in range(len(other.points)):
            other.refPoint = other.points[i]
            other.prevRefPoint = other.prevPoints[i]

            for geometry in lines:
                lineInfo = geometry.line(other)
                if lineInfo is None:
                    continue
                normal, penetration = lineInfo

                #static to object
                if self.static and not other.static:
                    other.pos -= normal * penetration
                    other.vel -= other.vel.dot(normal) * normal

                    if normal.y <= -.5:
                        other.grounded = True
                    # elif normal.y >= .5:
                    # else:

                # object to static
                elif not self.static and other.static:
                    self.pos -= normal*penetration
                    self.vel -= self.vel.dot(normal) * normal
                    if normal.y <= -.5:
                        self.grounded = True


class Geometry:
    def __init__(self, p1, p2):
        self.p1 = pygame.Vector2(p1)
        self.p2 = pygame.Vector2(p2)
        self.edge = self.p2 - self.p1
        self.dx = self.p2.x - self.p1.x
        self.dy = self.p2.y - self.p1.y
        if pygame.Vector2(-self.dy,self.dx) != (0,0):
            self.normal = pygame.Vector2(-self.dy, self.dx).normalize()
        else: self.normal = (0,0)


    def line(self, other):
        pygame.draw.circle(screen, (255, 0, 0), (self.p1.x, self.p1.y), 5)

        penetration = (other.refPoint - self.p1).dot(self.normal)
        approaching = other.vel.dot(self.normal) <= 0

        edge_len_sq = self.edge.length_squared()
        if edge_len_sq == 0: t = 0.0
        else: t = (other.refPoint - self.p1).dot(self.edge) / edge_len_sq

        if t > 0 and t < 1 and penetration <= 0 and (other.prevRefPoint-self.p1).dot(self.normal) >= 0:
            return self.normal, penetration


class Square(Entity):
    def __init__(self, x, y, width, height, angle):
        super().__init__(x, y, width, height, angle)
        self.red = 128
        self.green = 128
        self.blue = 128

class Player(Entity):
    def __init__(self, x, y, width, height, angle):
        super().__init__(x, y, width, height, angle)
        self.red = 255
        self.green = 255
        self.blue = 255


    def detectInput(self, keys):
        global debug
        if debug == False:
            #Y movement
            if keys[pygame.K_UP] and self.grounded == True: self.vel.y = -15
            #X movement
            if keys[pygame.K_RIGHT]:
                self.vel.x += 1
                if self.vel.x >= 10: self.vel.x -= 2

            if keys[pygame.K_LEFT]:
                self.vel.x -= 1
                if self.vel.x <= -10: self.vel.x += 2
        else:
            if keys[pygame.K_UP]: self.vel.y = -5
            elif self.vel.y < 0: self.vel.y= 0
            if keys[pygame.K_DOWN]: self.vel.y = 5
            elif self.vel.y > 0: self.vel.y = 0
            if keys[pygame.K_LEFT]: self.vel.x = -5
            elif self.vel.x < 0: self.vel.x = 0
            if keys[pygame.K_RIGHT]: self.vel.x = 5
            elif self.vel.x > 0: self.vel.x = 0

player = Player(550, 100, 30, 40, 0)
box1 = Square(100, 300, 100, 100, 0)
box2 = Square(300, 300, 100, 100, 25)
box3 = Square(400, 500, 650, 100, 0)
box4 = Square(400, 300, 100, 300, 0)
box5 = Square(675, 325, 100, 100, 25)
box6 = Square(525, 350, 100, 100, 0)
objects = [box1, box2, player]
statics = [box3, box4, box5, box6]

running = True
while running:
    for event in pygame.event.get():
        keys = pygame.key.get_pressed()
        keypress = event.type == pygame.KEYDOWN and event.key
        if event.type == pygame.QUIT:
            running = False

        #debug
        if keypress == pygame.K_q:
            debug = not debug
            if player.gravity == 0: player.gravity = 1

        if keypress == pygame.K_w:
            player.pos.x, player.pos.y = pygame.mouse.get_pos()
            player.vel.y = 0
        if keypress == pygame.K_e:
            print(player.pos)
    screen.fill((0, 0, 0))  # clear screen (black)

    player.detectInput(keys)
    for entity in objects:
        entity.move()
        entity.grounded = False

    #Collision
    for entity in objects:
        for i in range(len(statics)):
            statics[i].static = True
            entity.box(statics[i])
    for entity in statics:
        for i in range(len(objects)):
            objects[i].static = False
            entity.box(objects[i])
    for entity in objects:
        for i in range(len(objects)):
            objects[i].static = False
            if objects[i] == entity:
                continue
            entity.box(objects[i])
            objects[i].box(entity)


    #Draw
    for entity in objects:
        entity.drawRect(screen)
    for entity in statics:
        entity.drawRect(screen)

    for entity in objects: entity.prevPoints = entity.points


    pygame.display.flip()
    clock.tick(60)

pygame.quit()

class Entity:
    def __init__(self, x, y, width=100, height=100, angle=0):
        self.pos = pygame.Vector2(x, y)
        self.width = width
        self.height = height
        self.vel = pygame.Vector2(0, 0)
        self.gravity = 1
        self.grounded = False
        self.angle = angle % 360
        self.red = 0
        self.green = 0
        self.blue = 0
        self.static = True
        self.mass = self.width * self.height
        self.prevPos = pygame.Vector2(self.pos.copy())
        self.raduis = 0

    def move(self, keys):
        if self.vel.x != 0:
            if self.vel.x >= -.5 and self.vel.x <= .5:
                self.vel.x = 0
            elif self.vel.x > 0:
                self.vel.x -= .5
            elif self.vel.x < 0:
                self.vel.x += .5
            if self.grounded:
                if self.vel.x > 0 and not keys[pygame.K_RIGHT]:
                    self.vel.x -= 1
                elif self.vel.x < 0 and not keys[pygame.K_LEFT]:
                    self.vel.x += 1
        if self.vel.y >= 17: self.vel.y = 17
        self.pos += self.vel
        if lessgrav and self is player and self.vel.y > 0: self.gravity = .3
        self.vel.y += self.gravity

    def updatePrevPos(self):
        self.prevPos = pygame.Vector2(self.pos.x, self.pos.y)

    def drawRect(self, screen):
        surf = pygame.Surface((self.width, self.height), pygame.SRCALPHA)
        surf.fill((self.red, self.green, self.blue))
        if debugToggle: pygame.draw.rect(screen, (self.red / 2 + backgroundRed, self.green / 2 + backgroundGreen,
                                                  self.blue / 2 + backgroundBlue),
                                         (self.prevPos.x - self.width / 2, self.prevPos.y - self.height / 2, self.width,
                                          self.height), )

        rotated = pygame.transform.rotate(surf, self.angle)
        rect = rotated.get_rect(
            center=(self.pos.x, self.pos.y)
        )
        screen.blit(rotated, rect)
        if debugToggle: pygame.draw.circle(screen, (255, 0, 0), (self.pos.x, self.pos.y), 5)


    def screenLoop(self):
        if self.pos.y - self.height / 2 > y_screen:
            self.pos.y = (0 - self.height / 2)
            if self == player:
                if isinstance(levels[0][0], Default): createLevelSet()
                else: enterLevel()
        elif self.pos.x - self.width / 2 > x_screen:
            self.pos.x = 0 - self.width / 2
        elif self.pos.x + self.width / 2 < 0:
            self.pos.x = x_screen + self.width / 2

    def intersectingBox(self, other):
        if \
                ((other.pos.x - other.width / 2) <= (self.pos.x + self.width / 2) and
                (other.pos.x + other.width / 2) >=(self.pos.x - self.width / 2) and
                (other.pos.y + other.height / 2) >= (self.pos.y - self.height / 2) and
                (other.pos.y - other.height / 2) <= (self.pos.y + self.height / 2)):
            return True
        else:
            return False
    def hitBox(self, other):
        global ledgegrab, mobilize, objects, statics
        direction = None
        # Floor
        if (
                ledgegrab and
                (self.pos.y - self.height / 2) >= (other.pos.y - other.height / 2) and
                (self.pos.x + self.width / 2) > (other.pos.x - other.width / 2) and
                (self.pos.x - self.width / 2) < (other.pos.x + other.width / 2) and
                (self.prevPos.y - self.height / 2) <= (other.pos.y - other.height / 2)):
            self.pos.y = other.pos.y - other.height / 2 + self.height / 2
            self.vel.y = 0
            self.grounded = True

        if (
                (self.pos.y + self.height / 2) >= (other.pos.y - other.height / 2) and
                (self.pos.x + self.width / 2) > (other.pos.x - other.width / 2) and
                (self.pos.x - self.width / 2) < (other.pos.x + other.width / 2) and
                (self.prevPos.y + self.height / 2) <= (other.pos.y - other.height / 2)):

            self.pos.y = other.pos.y - other.height / 2 - self.height / 2
            self.vel.y = 0
            self.grounded = True
            if self is player:
                if self.dive != 0:
                    if self.vel.x > 0 and keys[pygame.K_DOWN]:
                        self.slideTimer = 15
                        self.pos.y -= 5
                    if self.vel.x < 0 and keys[pygame.K_DOWN]:
                        self.slideTimer = -15
                        self.pos.y -= 5
            direction = (0, -1)
        # Right Wall
        elif \
                ((self.pos.x - self.width / 2) < (other.pos.x + other.width / 2) and
                 (self.pos.y + self.height / 2) > (other.pos.y - other.height / 2) and
                 (self.pos.y - self.height / 2) < (other.pos.y + other.height / 2) and
                 (self.prevPos.x - self.width / 2) >= (other.pos.x + other.width / 2)):
            if dash == False or (dash and player.dive == 0):
                self.pos.x = other.pos.x + other.width / 2 + self.width / 2
                self.vel.x = 0
                if self == player:
                    player.jumpSlide = False
                    if not self.grounded:
                        if self.dive == 0:
                            player.wallTimerLeft = 0
                            player.kindaRightWalled = True
                            if keys[pygame.K_LEFT]: player.rightWalled = True
                            player.slideTimer = 0
                        else:
                            player.dive = 0
                            player.vel.x = 15
                            player.gravity = 1
                            if mobilize:
                                objects.append(other)
                                statics.remove(other)
                direction = (1, 0)

            # Left Wall
        elif \
                ((self.pos.x + self.width / 2) > (other.pos.x - other.width / 2) and
                 (self.pos.y + self.height / 2) > (other.pos.y - other.height / 2) and
                 (self.pos.y - self.height / 2) < (other.pos.y + other.height / 2) and
                 (self.prevPos.x + self.width / 2) <= (other.pos.x - other.width / 2)):
            if dash == False or (dash and player.dive == 0):
                self.pos.x = other.pos.x - other.width / 2 - self.width / 2
                self.vel.x = 0
                if self == player:
                    player.jumpSlide = False
                    if not self.grounded:
                        if player.dive == 0:
                            player.wallTimerRight = 0
                            player.kindaLeftWalled = True
                            if keys[pygame.K_RIGHT]: player.leftWalled = True
                            player.slideTimer = 0
                        else:
                            player.dive = 0
                            player.vel.x = -15
                            player.gravity = 1
                            if mobilize:
                                objects.append(other)
                                statics.remove(other)

                direction = (-1, 0)
            # Ceiling
        elif (
                (self.pos.y - self.height / 2) < (other.pos.y + other.height / 2) and
                (self.pos.x + self.width / 2) > (other.pos.x - other.width / 2) and
                (self.pos.x - self.width / 2) < (other.pos.x + other.width / 2) and
                (self.prevPos.y - self.height / 2) >= (other.pos.y + other.height / 2)):
            self.pos.y = other.pos.y + other.height / 2 + self.height / 2
            self.vel.y = 0
            direction = (0, 1)

        inc = 0
        colliding = True
        if direction != None:
            objectCollisions = [(self, None)]
            while colliding:
                colliding = False
                for info in objectCollisions:
                    refObject, prevObject = info
                    objectCollisions.remove(info)
                    for colObject in objects:
                        if refObject == colObject: continue
                        if refObject == prevObject: continue
                        if refObject.intersectingBox(colObject):
                            collided = False
                            if direction == (0, -1) and refObject.prevPos.y - refObject.height/2 >= colObject.prevPos.y + colObject.height/2:
                                colliding = True
                                collided = True
                                colObject.pos.y = refObject.pos.y - refObject.height/2 - colObject.height/2
                                colObject.grounded = True
                                colObject.vel.y = 0
                            elif direction == (1, 0) and refObject.prevPos.x + refObject.width/2 <= colObject.prevPos.x - colObject.width/2:
                                colliding = True
                                collided = True
                                colObject.pos.x = refObject.pos.x + refObject.width/2 + colObject.width/2
                                colObject.vel.x = 0
                            elif direction == (-1, 0) and refObject.prevPos.x - refObject.width/2 >= colObject.prevPos.x + colObject.width/2:
                                colliding = True
                                collided = True
                                colObject.pos.x = refObject.pos.x - refObject.width/2 - colObject.width/2
                                colObject.vel.x = 0
                            elif direction == (0, 1) and refObject.prevPos.y + refObject.height/2 <= colObject.prevPos.y - colObject.height/2:
                                colliding = True
                                collided = True
                                colObject.pos.y = refObject.pos.y + refObject.height/2 + colObject.height/2
                                colObject.vel.y = 0
                            if collided:
                                for collision in collisions:
                                    if (collision[0] == refObject and collision[1] == colObject) or (collision[0] == colObject and collision[1] == refObject):
                                        collisions.remove(collision)

                                objectCollisions.append((colObject, refObject))
                inc += 1
                if inc >= 30:
                    colliding = False

                    print("it broke")


    def objectHitBox(self, other):
        distance = None
        # Floor
        if (
                (self.pos.y + self.height / 2) >= (other.pos.y - other.height / 2) and
                (self.pos.x + self.width / 2) > (other.pos.x - other.width / 2) and
                (self.pos.x - self.width / 2) < (other.pos.x + other.width / 2) and
                (self.prevPos.y + self.height / 2) <= (other.pos.y - other.height / 2)):
            distance = pygame.Vector2(0, (self.pos.y + self.height / 2) - (other.pos.y - other.height / 2))

            self.grounded = True
        # Right Wall
        elif \
                ((self.pos.x - self.width / 2) <= (other.pos.x + other.width / 2) and
                 (self.pos.y + self.height / 2) > (other.pos.y - other.height / 2) and
                 (self.pos.y - self.height / 2) < (other.pos.y + other.height / 2) and
                 (self.prevPos.x - self.width / 2) >= (other.pos.x + other.width / 2)):
            distance = pygame.Vector2((self.pos.x - self.width / 2) - (other.pos.x + other.width / 2), 0)

            if self == player:
                player.jumpSlide = False
                if not self.grounded:
                    if player.dive == 0:
                        player.wallTimerLeft = 0
                        player.kindaRightWalled = True
                        if keys[pygame.K_LEFT]: player.rightWalled = True
                    else:
                        player.dive = 0
                        player.vel.x = 6
                        player.gravity = 1
        # Left Wall
        elif \
                ((self.pos.x + self.width / 2) >= (other.pos.x - other.width / 2) and
                 (self.pos.y + self.height / 2) > (other.pos.y - other.height / 2) and
                 (self.pos.y - self.height / 2) < (other.pos.y + other.height / 2) and
                 (self.prevPos.x + self.width / 2) <= (other.pos.x - other.width / 2)):
            distance = pygame.Vector2((self.pos.x + self.width / 2) - (other.pos.x - other.width / 2), 0)
            if self == player:
                player.jumpSlide = False
                if not self.grounded:
                    if player.dive == 0:
                        player.wallTimerRight = 0
                        player.kindaLeftWalled = True
                        if keys[pygame.K_RIGHT]: player.leftWalled = True
                    else:
                        player.dive = 0
                        player.vel.x = -6
                        player.gravity = 1
        # Cieling
        elif (
                (self.pos.y - self.height / 2) <= (other.pos.y + other.height / 2) and
                (self.pos.x + self.width / 2) > (other.pos.x - other.width / 2) and
                (self.pos.x - self.width / 2) < (other.pos.x + other.width / 2) and
                (self.prevPos.y - self.height / 2) >= (other.pos.y + other.height / 2)):
            distance = pygame.Vector2(0, (self.pos.y - self.height / 2) - (other.pos.y + other.height / 2))
        if distance != None: collisions.append((self, other, distance))



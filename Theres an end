class Player(Entity):
    def __init__(self, x, y, width, height, angle):
        super().__init__(x, y, width, height, angle)
        self.red = 255
        self.green = 255
        self.blue = 255
        self.friction = .9
        self.jumpTimer = 0
        self.rightWalled = False
        self.leftWalled = False
        self.kindaRightWalled = False
        self.kindaLeftWalled = False
        self.wallTimerRight = 0
        self.wallTimerLeft = 0
        self.coyote = 0
        self.coyoteRight = 0
        self.coyoteLeft = 0
        self.coyoteTime = 5
        self.jumpBuffer = 0
        self.slideTimer = 0
        self.dive = 0
        self.jumpSlide = False
        self.twirlTimer = 0
        self.bounce = False
        self.hasDashed = False
        self.facing = 0

    def detectInput(self, keys, upPress, downPress):
        global twirl, bounce, dash
        if upPress and not self.grounded: self.jumpBuffer = 5
        if self.jumpBuffer > 0: self.jumpBuffer -= 1
        if self.grounded:
            self.dive = 0
            self.gravity = 1
            self.bounce = False
            if self.coyote == 0: self.jumpSlide = False
            self.hasDashed = False

        if not fly:
            # Y movement
            if self.rightWalled or self.leftWalled:
                if self.vel.y > 0:
                    self.vel.y *= 0.75
                if self.kindaRightWalled or self.rightWalled: self.coyoteRight = self.coyoteTime + 5
                if self.kindaLeftWalled or self.leftWalled: self.coyoteLeft = self.coyoteTime + 5
            if self.grounded:
                self.coyote = self.coyoteTime
            if keys[pygame.K_UP]:
                # ground Jump
                if self.grounded or self.coyote != 0:
                    self.vel.y -= 8
                    self.jumpTimer = 4
                    if not self.grounded:
                        self.vel.y = -10
                if self.jumpTimer > 0:
                    self.vel.y -= .25
                    self.jumpTimer -= 1
                self.gravity = .75
                # wall jump
            if (self.rightWalled or self.coyoteRight != 0) and not self.grounded and self.jumpBuffer > 0:
                self.vel = pygame.Vector2(8, -7)
                self.wallTimerRight = 7
                self.coyoteRight = 0
                self.wallTimerLeft = 0
            if self.wallTimerRight != 0:
                if self.wallTimerRight > 0:
                    if keys[pygame.K_UP]: self.vel.y -= self.wallTimerRight * .2
                    self.wallTimerRight -= 2
                    if keys[pygame.K_LEFT]: self.vel.x += 1
                    if self.wallTimerRight == -1: self.wallTimerRight = -11
                elif -16 < self.wallTimerRight < 0:
                    if keys[pygame.K_LEFT]: self.vel.x += 1
                    if keys[pygame.K_RIGHT]: self.vel.x -= .5
                    self.wallTimerRight += 1
                    if self.wallTimerRight == -1: self.wallTimerRight = -25
                elif self.wallTimerRight < -16:
                    if keys[pygame.K_LEFT]: self.vel.x += .5
                    self.wallTimerRight += 1
                    if self.wallTimerRight == -16: self.wallTimerRight = 0

            if (self.leftWalled or self.coyoteLeft != 0) and not self.grounded and self.jumpBuffer > 0:
                self.vel = pygame.Vector2(-8, -7)
                self.wallTimerLeft = 7
                self.coyoteLeft = 0
                self.wallTimerRight = 0
            if self.wallTimerLeft != 0:
                if self.wallTimerLeft > 0:
                    if keys[pygame.K_UP]: self.vel.y -= self.wallTimerLeft * .2
                    self.wallTimerLeft -= 2
                    if keys[pygame.K_RIGHT]: self.vel.x -= 1
                    if self.wallTimerLeft == -1: self.wallTimerLeft = -11
                elif -16 < self.wallTimerLeft < 0:
                    if keys[pygame.K_RIGHT]: self.vel.x -= 1
                    if keys[pygame.K_LEFT]: self.vel.x += .5
                    self.wallTimerLeft += 1
                    if self.wallTimerLeft == -1: self.wallTimerLeft = -25
                elif self.wallTimerLeft < -16:
                    if keys[pygame.K_RIGHT]: self.vel.x -= .5
                    self.wallTimerLeft += 1
                    if self.wallTimerLeft == -16: self.wallTimerLeft = 0
            if self.coyoteLeft > 0: self.coyoteLeft -= 1
            if self.coyoteRight > 0: self.coyoteRight -= 1
            if self.coyote > 0: self.coyote -= 1

            if keys[pygame.K_DOWN]:
                if not self.grounded and not self.bounce: self.vel.y += 2
                elif self.grounded and self.prevPos.y != self.pos.y and bounce:
                    self.vel.y = -self.gravity*20
                    self.bounce = True

            # X movement
            if self.slideTimer == 0:
                if keys[pygame.K_RIGHT]:
                    self.facing = 1
                    self.vel.x += 1
                    if self.vel.x >= 7: self.vel.x -= .5
                    if downPress and self.grounded: self.slideTimer = 15

                if keys[pygame.K_LEFT]:
                    self.facing = 0
                    self.vel.x -= 1
                    if self.vel.x <= -7: self.vel.x += .5
                    if downPress and self.grounded: self.slideTimer = -15
                if self.vel.x > 0 and self.grounded and not keys[pygame.K_RIGHT]: self.vel.x -= 1
                if self.vel.x < 0 and self.grounded and not keys[pygame.K_LEFT]: self.vel.x += 1



            elif self.slideTimer != 0:

                if self.coyote != 0:
                    if upPress:
                        if self.slideTimer > 0:
                            self.slideTimer = 1
                        else:
                            self.slideTimer = -1
                        self.jumpSlide = True
                        self.vel.y = -10

                    if self.slideTimer == 15 or self.slideTimer == -15:
                        self.width = 30
                        self.height = 20
                        self.pos.y += 5
                        if self.slideTimer > 0:
                            self.pos.x -= 5
                        else:
                            self.pos.x += 5
                    if self.slideTimer > 0:
                        self.vel.x = 14
                        self.slideTimer -= 1
                    else:
                        self.vel.x = -14
                        self.slideTimer += 1
                    if self.slideTimer == 1 or self.slideTimer == -1:
                        self.vel.x = 0
                        if self.slideTimer > 0:
                            self.vel.x = 10
                            self.pos.x -= 10
                        else:
                            self.vel.x = -10
                            self.pos.x += 10
                        self.slideTimer = 0
                elif self.coyote == 0:
                    self.slideTimer = 0

            if not self.grounded and downPress and self.dive == 0:
                if keys[pygame.K_RIGHT]: self.dive = 10
                if keys[pygame.K_LEFT]: self.dive = -10
            if self.dive != 0:
                if not dash:
                    if self.dive > 0:
                        self.width = 30
                        self.height = 20
                        if self.dive == 10: self.pos.x -= 5
                        if self.dive > 7: self.vel = pygame.Vector2(5, -.6)
                        elif  self.dive > 1: self.vel = pygame.Vector2(10, .75)
                        else:self.vel.x = 12
                        if self.dive > 1: self.dive -= 1


                    else:
                        self.width = 30
                        self.height = 20
                        if self.dive == -10: self.pos.x += 5
                        if self.dive < -7:self.vel = pygame.Vector2(-5, -.6)
                        elif self.dive < -1: self.vel = pygame.Vector2(-10, .75)
                        else: self.vel.x = -12
                        if self.dive < -1: self.dive += 1
                else:
                    if not self.hasDashed:
                        if self.dive > 0:
                            self.pos.x += 10
                            self.vel.y = 0
                            self.pos.y -= .5
                            if self.dive > 0: self.dive -= 1
                            if self.dive == 1: self.hasDashed = True
                        else:
                            self.pos.x -= 10
                            self.vel.y = 0
                            self.pos.y -= .5
                            if self.dive < 0: self.dive += 1
                            if self.dive == -1: self.hasDashed = True


            if (self.width != 20 or self.height != 30) and self.slideTimer == 0 and self.dive == 0:
                self.width = 20
                self.height = 30
                self.pos.y -= 5
            if self.jumpSlide:
                if self.vel.x < 0:
                    self.vel.x = -10
                    if keys[pygame.K_RIGHT]: self.jumpSlide = False
                elif self.vel.x > 0:
                    self.vel.x = 10
                    if keys[pygame.K_LEFT]: self.jumpSlide = False

                if keys[pygame.K_DOWN]: self.vel.y -= 2
            if self.twirlTimer > 0: self.twirlTimer -= 1
            if not self.grounded and upPress and twirl and self.twirlTimer == 0:
                self.vel.y = -7
                self.twirlTimer = 30
        # Debug
        elif fly and debugToggle:
            if keys[pygame.K_UP]:
                self.vel.y = -5
            elif self.vel.y < 0:
                self.vel.y = 0
            if keys[pygame.K_DOWN]:
                self.vel.y = 5
            elif self.vel.y > 0:
                self.vel.y = 0
            if keys[pygame.K_LEFT]:
                self.vel.x = -5
            elif self.vel.x < 0:
                self.vel.x = 0
            if keys[pygame.K_RIGHT]:
                self.vel.x = 5
            elif self.vel.x > 0:
                self.vel.x = 0

def updatetotals():
    global totalItems, totalLevels, totalFood, progress, levels
    if progress == 0: totalItems, totalLevels, totalFood = 2, 2, 2
    elif progress == 1: totalItems, totalLevels, totalFood = 2, 3, 3
    elif progress == 2: totalItems, totalLevels, totalFood = 3, 3, 4
    elif progress == 3: totalItems, totalLevels, totalFood = 4, 4, 5
    elif progress == 4: totalItems, totalLevels, totalFood = 4, 6, 6
    elif progress >= 5: levels = [([DefaultColor(x_screen/2, y_screen/2)], 128, 128, 64)]



class item(Entity):
    def __init__(self, x, y):
        self.pos = pygame.Vector2(x, y)

class Goal(item):
    def __init__(self, x, y, r):
        super().__init__(x, y)
        self.pos = pygame.Vector2(x, y)
        self.radius = r
        self.enterable = True

    def collect(self, other):
        global levels, currentLevel, items, progress
        self.enterable = True
        for item in items:
            if isinstance(item, Food):
                self.enterable = False
                break
        if self.pos.distance_to(other.pos) <= self.radius and self.enterable:
            if len(levels) != 0:
                if isinstance(levels[0][0], Default):
                    createLevelSet()
                    progress += 1
                    print("progress: ", progress)
                else: levels.remove(currentLevel)
            enterLevel()
    def drawCircle(self, screen):
        global backgroundGreen, backgroundBlue, backgroundRed
        if self.enterable: pygame.draw.circle(screen, (100, 100, 255), (self.pos), self.radius-10)
        else: pygame.draw.circle(screen, (backgroundRed+25, backgroundGreen+25, backgroundBlue+64), (self.pos), self.radius-10)

class Food(item):
    def __init__(self, x, y, r):
        super().__init__(x, y)
        self.pos = pygame.Vector2(x, y)
        self.radius = r

    def collect(self, other):
        if self.pos.distance_to(other.pos) <= self.radius:
            items.remove(self)
    def drawCircle(self, screen):
        pygame.draw.circle(screen, (255, 255, 255), (self.pos), self.radius-10)

class TimeStop(item):
    def __init__(self, x, y, r):
        super().__init__(x, y)
        self.pos = pygame.Vector2(x, y)
        self.radius = r
        self.collected = False

    def collect(self, other):
        global timestop
        if self.pos.distance_to(other.pos) <= self.radius:
            timestop = True
            items.remove(self)

    def drawCircle(self, screen):
        pygame.draw.circle(screen, (100, 200, 100), (self.pos), self.radius-10)

class LessGrav(item):
    def __init__(self, x, y, r):
        super().__init__(x, y)

def generateLevel():
    global objects, statics, player, sprites, items, backgroundRed, backgroundGreen, backgroundBlue
    resetWorld()
    r, g, b = random.randint(0, 45), random.randint(0, 45), random.randint(0, 45)
    currentLevels = []
    for i in range(4):
        for i in range(20):
            works = True
            Empty = True
            while Empty:
                Empty = False
                levelBlock = random.choice(levelPool)(random.randint(100, x_screen-100), random.randint(100, y_screen-100))
                if levelBlock.statics == []: Empty = True
            for level in currentLevels:
                if levelBlock.pos.x+levelBlock.width/2 >= level.pos.x - level.width/2 and levelBlock.pos.x-levelBlock.width/2 <= level.pos.x + level.width/2 and levelBlock.pos.y+levelBlock.height/2 >= level.pos.y - level.height/2 and levelBlock.pos.y-levelBlock.height/2 <= level.pos.y + level.height/2:
                    works = False
            if works:
                distance = pygame.Vector2(0,0)
                if levelBlock.width/2 + levelBlock.pos.x > x_screen: distance.x = levelBlock.pos.x + levelBlock.width/2 - x_screen
                if levelBlock.pos.y - levelBlock.height/2 < 0: distance.y = levelBlock.pos.y - levelBlock.height/2
                if levelBlock.pos.x - levelBlock.width/2 < 0: distance.x = levelBlock.pos.x - levelBlock.width/2
                if levelBlock.height/2 + levelBlock.pos.y > y_screen: distance.y = levelBlock.pos.y + levelBlock.width/2 - y_screen
                levelBlock.pos -= distance
                currentLevels.append(levelBlock)
                break
    return (currentLevels, r, g, b)
def makeLevel(yeeah):
    global backgroundRed, backgroundGreen, backgroundBlue, items, statics, objects
    items, statics, objects = [], [], [player]
    backgroundRed, backgroundGreen, backgroundBlue = yeeah[1], yeeah[2], yeeah[3]
    currentLevels = yeeah[0]
    for level in currentLevels:
        addItem = random.randint(0, 1)
        addFood = random.randint(0, 2)
        if addItem == 1 and level.statics != [] and itemPool != []: addItem = random.choice(level.statics)
        if addFood != 0 and level.statics != []: addFood = random.choice(level.statics)
        for box in level.statics:
            x, y, w, h, a = box
            if addItem is box:
                randItem = random.randint(0, len(itemPool)-1)
                items.append(itemPool[randItem](x+level.pos.x, y+level.pos.y-h/2-30, 30))
                itemPool.remove(itemPool[randItem])

            if addFood is box:
                afood = Food(x + level.pos.x, y + level.pos.y - h / 2 - 30, 30)
                items.append(afood)
                foodNum[1] += 1

            if level == currentLevels[0] and box == level.statics[0]:
                player.pos = pygame.Vector2(x + level.pos.x, y + level.pos.y - h / 2 - player.height / 2 - 5)
                tupe = (1, -1)
                if isinstance(level, MidWall): player.pos.x += random.randint(30, (box[2]-30)//2) * random.choice(tupe)


            if level == currentLevels[-1] and box == level.statics[-1]:
                goal = Goal(level.pos.x+box[0], level.pos.y+box[1]-h/2 - 30, 30)
                items.append(goal)
            elif level.statics == []:
                goal = Goal(level.pos.x, level.pos.y, 30)
                items.append(goal)
            square = Square(x + level.pos.x, y + level.pos.y, w, h, a)
            statics.append(square)
            square.red = level.red
            square.green = level.green
            square.blue = level.blue
        for item in items:
            inside = True
            while inside:
                inside = False
                for box in statics:
                    if item.pos.x < box.pos.x+box.width/2 and item.pos.x > box.pos.x-box.width/2 and item.pos.y > box.pos.y-box.height/2 and item.pos.y < box.pos.y + box.height/2:
                        inside = True
                        item.pos.y -= 10

        for box in level.objects:
            x, y, w, h, a = box
            square = Square(x + level.pos.x, y + level.pos.y, w, h, a)
            objects.append(square)

        if debugToggle:
            sprites.append((screen, (0), (level.pos.x-level.width/2, level.pos.y-level.height/2, level.width, level.height)))




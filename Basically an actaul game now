        self.pos = pygame.Vector2(x, y)

class Goal(item):
    def __init__(self, x, y, r):
        super().__init__(x, y)
        self.pos = pygame.Vector2(x, y)
        self.radius = r


    def collect(self, other):
        global foodNum, levels, currentLevel
        if self.pos.distance_to(other.pos) <= self.radius and foodNum[0] >= foodNum[1]:
            if len(levels) > 1: levels.remove(currentLevel)
            enterLevel()
    def drawCircle(self, screen):
        global backgroundGreen, backgroundBlue, backgroundRed
        if foodNum[0] == foodNum[1]: pygame.draw.circle(screen, (100, 100, 255), (self.pos), self.radius-10)
        else: pygame.draw.circle(screen, (backgroundRed+25, backgroundGreen+25, backgroundBlue+64), (self.pos), self.radius-10)

